set -e

npm run format:check
bash scripts/check-env-drift.sh
npm run check:tokens

if command -v shellcheck >/dev/null 2>&1; then
  find ./scripts -type f \( -name '*.sh' -o -name '*.bash' \) -print0 \
    | xargs -0 shellcheck --severity=warning --format=gcc
else
  echo "warn: shellcheck not installed — CI will still check. Install: apt install shellcheck (or brew install shellcheck)"
fi
