# Playwright shared auth state — generated per-run, contains a live
# session cookie, must never be committed.
e2e/.auth/

# WIP scratch directory (local only)
docs/wip/

# Server-side runtime data (dev-generated VAPID key, etc.) — never committed.
data/

# Scratch screenshots (Playwright MCP saves to repo root by default).
# Repo-root only — keeps any deliberate `assets/*.png` etc. unaffected.
/*.png
/*.jpg
/*.jpeg
