{
  "name": "projekt-manager",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:e2e": "node e2e/ensure-db.mjs && concurrently -k -n server,client -c blue,green \"npm:dev:e2e:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env src/server/start.ts",
    "dev:e2e:server": "tsx watch src/server/start.ts",
    "build": "tsc --noEmit && vite build && npm run build:server",
    "build:server": "esbuild src/server/start.ts src/server/backup-runner.ts src/server/deploy-preflight-cli.ts --bundle --platform=node --outdir=dist/server --format=esm --packages=external",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"**/*.md\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"**/*.md\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:tokens": "bash scripts/check-theme-tokens.sh",
    "prepare": "husky || true",
    "postinstall": "patch-package"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": "prettier --write",
    "**/*.md": "prettier --write"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@cantoo/pdf-lib": "^2.6.5",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@noble/hashes": "^2.2.0",
    "@uploadcare/image-shrink": "^6.18.4",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "client-zip": "^2.5.0",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "eruda": "^3.4.3",
    "fastify": "^5.8.5",
    "fflate": "^0.8.2",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "web-push": "^3.6.7",
    "xmllint-wasm": "^5.2.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "concurrently": "^9.2.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.3",
    "unpdf": "^1.6.2",
    "vite": "^8.0.13",
    "vitest": "4.1.6"
  }
}
