# Layer 2 encrypted backup service — see ADR-0020.
#
# Two-stage build:
#   1. `appsrc` stage — pulls the compiled app bundle so we can COPY
#      `dist/server/backup-runner.js` (and its friends) into the final
#      image. APP_IMAGE_TAG must match the tag deployed on the same
#      commit (scripts/deploy.sh exports it before `docker compose up`).
#   2. final stage — node:22.22.3-alpine with postgresql17 (server +
#      client) and the rest of the operational toolchain layered on top,
#      plus the backend bundle from stage 1.
#
# BASE IMAGE CHOICE (F1): node:22.22.3-alpine instead of
# postgres:17-alpine. Reason: ADR-0009 pins the app runtime at node
# v22.22.3. postgres:17-alpine is tracking Alpine 3.23, whose `apk add
# nodejs` resolves to v24.x — that would silently diverge from the app
# image's v22 line and break the parity rule ADR-0009 exists to
# enforce. node:22.22.3-alpine is on Alpine 3.22, which ships
# postgresql17 server + client packages directly, so initdb /
# postgres / pg_restore / pg_isready / pg_dump / psql are all
# available for the Tier 1 verify-on-create path (ADR-0020 §Decision,
# docs/spec/architecture.md §11.10) without multi-stage binary
# shuffling.
# No default: callers (scripts/deploy.sh via the CI build-and-push job,
# or an operator-run `docker build --build-arg`) MUST supply the tag.
# Dropping the `=iteration-7-data` default closes the H2 audit finding —
# a stale mutable branch tag could silently ship the wrong code.
ARG APP_IMAGE_TAG
# hadolint ignore=DL3006  # tag is set by scripts/deploy.sh per commit
FROM ghcr.io/projekt-manager-org/projekt-manager:${APP_IMAGE_TAG} AS appsrc

FROM node:22.22.3-alpine

# Package roles:
#   postgresql17         — server binaries (initdb, postgres) used by
#                          the Tier 1 verify path which spawns an
#                          ephemeral Postgres over a unix socket inside
#                          this container (ADR-0020 §Decision). Version
#                          is pinned at the major in the package name —
#                          Alpine 3.22 ships 17.x, which tracks the
#                          `db` service's postgres:17-alpine image.
#                          Creates the `postgres` system user (UID 70)
#                          we run the container as — see USER below.
#   postgresql17-client  — pg_restore, pg_dump, pg_isready, psql.
#                          Used by the backend backup-runner for the
#                          manifest + round-trip verify.
#   postgresql17-contrib — contrib extensions (pg_trgm, etc.). The
#                          Tier 1 verify path runs pg_restore against
#                          the ephemeral Postgres, which executes the
#                          dump's `CREATE EXTENSION pg_trgm` (backing
#                          the audit_log.entity_label GIN trigram
#                          index). Alpine's base postgresql17 package
#                          does not carry contrib — it must be
#                          installed separately or verify fails with
#                          "extension pg_trgm is not available".
#   age                  — envelope encryption (asymmetric recipient
#                          in env; private identity operator-held).
#   bash                 — load-drill-key.sh uses bash idioms (pipefail,
#                          [[, arrays, $'\004' EOT terminator for the
#                          tmpfs paste). Alpine's default /bin/sh is ash.
#   findmnt              — used by load-drill-key.sh's tmpfs-invariant
#                          check (AC-175 safety gate). Without it the
#                          script falls back to /proc/mounts parsing
#                          which is strictly less reliable.
#
# What's no longer here (#199):
#   - dcron / tzdata / su-exec — the schedule moved to in-process
#     `croner` inside the backend bundle (see backup-runner.ts).
#     croner reads timezones via the JS runtime's IANA `Intl` API;
#     node:22-alpine bundles full ICU + tzdata so Europe/Berlin works
#     without an OS package. If the base image ever switches to a slim
#     runtime without ICU, croner silently falls back to UTC and the
#     schedule drifts by an hour twice a year — verify ICU presence
#     before any such switch. su-exec is gone because the container
#     now runs as the `postgres` user directly (USER directive below);
#     ephemeralPg.ts no longer demotes.
#   - jq / coreutils / dcron-only utilities — the scripts that needed
#     them (run-backup.sh / run-drill.sh / crontab) collapsed into the
#     Node bundle when the schedule moved in-process.
#
# No explicit version pins here (the db-image parity via
# postgresql17's major version pin is what governs cross-environment
# compatibility — ADR-0009); everything else tracks Alpine 3.22.
RUN apk add --no-cache \
      postgresql17 \
      postgresql17-client \
      postgresql17-contrib \
      age \
      bash \
      findmnt

# Pull the compiled backend bundle + node_modules from the app image.
# This gives us `dist/server/backup-runner.js` without rebuilding the
# TypeScript here. It also guarantees the backup service runs the
# EXACT same backend code as the deployed app — no skew between a
# `runBackup` definition used by the web handlers and one used by
# the in-container scheduler.
COPY --from=appsrc /app/node_modules /app/node_modules
COPY --from=appsrc /app/dist         /app/dist
COPY --from=appsrc /app/package.json /app/package.json

# Operator helper: the tmpfs drill-key loader. Copied into
# /usr/local/bin/ so operators can `docker compose exec backup load-drill-key`
# without typing the full path. The script itself is shell because it
# is interactive (reads a pasted identity from stdin); the operational
# pipeline never invokes it on a schedule.
COPY scripts/backup/load-drill-key.sh /usr/local/bin/load-drill-key
RUN chmod +x /usr/local/bin/load-drill-key

# Tmpfs-destination directory for the operator-loaded drill identity.
# The actual mount is injected by compose with uid=70,gid=70,mode=0700
# (see docker-compose.yml services.backup.tmpfs). We pre-create the
# mountpoint with matching ownership so if compose's tmpfs directive
# is ever accidentally removed, the script path still exists (and
# load-drill-key.sh's tmpfs-invariant check refuses to write —
# defense in depth for AC-175).
RUN mkdir -p /run/drill-key \
 && chown postgres:postgres /run/drill-key \
 && chmod 0700 /run/drill-key

# Run as the `postgres` system user (UID 70, created by the
# postgresql17 apk package). Resolves Trivy IaC DS-0002 at the
# architectural layer — no `.trivyignore` entry needed.
#
# Why this is now possible (#199):
#   - The scheduler moved from `dcron` (which historically ran as
#     root because CAP_SETUID is needed to exec entries on behalf of
#     other users) to in-process `croner` inside the Node bundle.
#     Node-as-PID-1 needs no special caps to run its own children.
#   - The ephemeral verify Postgres no longer needs a demotion step:
#     it spawns directly under this UID. The postgres binary's
#     refusal-to-run-as-uid-0 rule was the original justification
#     for `su-exec`; with UID 70 it just works.
#   - The tmpfs at /run/drill-key is mounted uid=70,gid=70,mode=0700
#     so the in-container user can read/write the loaded identity.
#
# The image stays compose-level `read_only: true`; writes are still
# confined to the tmpfs and /tmp.
USER postgres

# Single-process entrypoint: `node backup-runner.js schedule`. croner
# registers the cron jobs and keeps the event loop alive via its
# internal setTimeout. SIGTERM from `docker stop` triggers a graceful
# drain (stop jobs, await in-flight ticks, close the DB pool, exit 0)
# — see scheduleSubcommand in src/server/backup-runner.ts.
#
# No `init: true` needed in compose. The historical reason was dcron's
# fork()+setpgid() per cron entry tripping Docker's PID-1 protection;
# croner does not fork. Node-as-PID-1 reaps its own children via libuv
# (ephemeralPg.ts's postgres/initdb/pg_restore subprocesses are all
# awaited, so no orphan-reaping concern).
ENTRYPOINT ["node", "/app/dist/server/backup-runner.js"]
CMD ["schedule"]
