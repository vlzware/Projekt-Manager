# =============================================================================
# Projekt-Manager — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values.
# Lines marked [CHANGE IN PROD] MUST be changed before production deployment.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Connection string for the application.
# Docker default: postgresql://pm:<POSTGRES_PASSWORD>@db:5432/projekt_manager
# Local default:  postgresql://pm:<POSTGRES_PASSWORD>@localhost:5432/projekt_manager
DATABASE_URL=postgresql://pm:changeme@localhost:5432/projekt_manager

# Password for the 'pm' database user.                         [CHANGE IN PROD]
POSTGRES_PASSWORD=changeme

# --- Object Storage (MinIO container) ----------------------------------------
# Root credentials for the MinIO container itself.              [CHANGE IN PROD]
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# --- Object Storage (application S3 client) ----------------------------------
# How the app connects to the S3-compatible storage.
# In Docker: http://storage:9000 — In local dev: http://localhost:9000
# NOTE: STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY must match MINIO_ROOT_USER /
# MINIO_ROOT_PASSWORD respectively (same credentials, different context).
STORAGE_ENDPOINT=http://storage:9000
STORAGE_BUCKET=projekt-manager
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme

# --- Application -------------------------------------------------------------
# Fully qualified domain for Caddy reverse proxy / TLS cert.   [CHANGE IN PROD]
DOMAIN=localhost

# Port the Fastify server listens on (inside the container).
PORT=3000

# Runtime mode. Controls security checks, logging verbosity, seed prevention.
# Values: development | production
NODE_ENV=development

# Seed mode (dev only — ignored when NODE_ENV=production):
#   true  = seed if database is empty (safe default)
#   force = wipe and re-seed (when seed data structure changes)
#   false = skip seeding
SEED=true

# --- Reverse proxy / TLS (production only) -----------------------------------
# Cloudflare API token for Caddy DNS-01 ACME challenges. Required when DOMAIN
# is set to a real domain. Token MUST be a scoped API Token (not the Global
# API Key) with permissions Zone:Zone:Read + Zone:DNS:Edit on the single zone
# matching DOMAIN. Record the issue date and rotate per #48.   [CHANGE IN PROD]
CLOUDFLARE_API_TOKEN=

# Host IP that Caddy's :443 listener is published on. In production, set to
# the WireGuard server interface address (typically 10.213.17.1) so Caddy is
# only reachable through the VPN. Leave unset for local dev — defaults to
# 127.0.0.1 (loopback only).                                   [CHANGE IN PROD]
WG_BIND_IP=
# Note: for the initial bootstrap of a new deployment (first-ever Let's Encrypt
# cert issuance), see docs/ops/caddy-tls-bootstrap.md. The procedure is a
# manual Caddyfile edit, not an env-var toggle.

# --- First-run admin bootstrap (production only) -----------------------------
# Creates the very first admin account on a fresh deployment, exactly once.
# See ADR-0010 and issue #57 for the rationale.
#
# Ritual (MUST be followed on every fresh deploy):
#   1. Set BOOTSTRAP_ADMIN_USERNAME and BOOTSTRAP_ADMIN_PASSWORD below to a
#      strong, unique username/password pair. Both must be set, or neither.
#      Policy: password ≥8 chars, ≤72 UTF-8 bytes, not in the common-password
#      blocklist. Exactly-one-set is a startup error — the service will
#      refuse to start.
#   2. Deploy.
#   3. Log in as this user, change the password immediately (this iteration
#      has no change-password UI — see docs/ops/server-setup.md Phase 8.1
#      for the curl rotation procedure), log out and back in to confirm.
#   4. REMOVE the three vars below from .env (comment out or delete the
#      values) and redeploy.
#   5. Verify: the second deploy should log no bootstrap warning and the
#      account should still work.
#
# Once the users table is non-empty the bootstrap is a permanent no-op —
# leftover values in .env are ignored, not re-applied — but leaving plaintext
# credentials on disk is a leak surface and the removal step is required
# hygiene, not just correctness.                             [CHANGE IN PROD]
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
# Optional. Defaults to BOOTSTRAP_ADMIN_USERNAME if unset.
BOOTSTRAP_ADMIN_DISPLAY_NAME=
