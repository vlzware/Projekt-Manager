# Projekt-Manager — Local Development
# ====================================
# cp .env.example .env — ready to use, no edits needed.
# For production, see .env.production.example.

# --- Database ---
DATABASE_URL=postgresql://pm:changeme@localhost:5432/projekt_manager
POSTGRES_PASSWORD=changeme

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=projekt-manager
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme

# --- Application ---
DOMAIN=localhost
PORT=3000
NODE_ENV=development

# Seed demo data on first start. Set to "force" to wipe and re-seed.
SEED=true

# How often (minutes) the background reaper sweeps expired sessions from
# the DB. Positive integer; default 60. Lower values tighten revocation
# latency at the cost of more DB traffic.
# SESSION_CLEANUP_INTERVAL_MINUTES=60

# --- LLM Email Extraction (ADR-0016, optional) ---
# Feature is disabled when the key is absent.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Web Push / VAPID (ADR-0023, optional) ---
# Push delivery is disabled when any of these are absent — the UI opt-in
# affordance surfaces a "not configured" notice; the server dispatcher
# falls back to a no-op. Generate a keypair:
#   npx web-push generate-vapid-keys --json
# The client fetches the public key at runtime from
# GET /api/push/vapid-public-key, so a single server-side VAPID_PUBLIC_KEY
# is the source of truth. VAPID_PRIVATE_KEY stays server-side only; never
# commit it. VITE_VAPID_PUBLIC_KEY is an optional local-dev fallback used
# only when the endpoint is unreachable (e.g. `npm run dev:client` without
# the server) — leave it blank in normal dev.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost
VITE_VAPID_PUBLIC_KEY=

# --- Not used in dev (production only) ---
CLOUDFLARE_API_TOKEN=
WG_BIND_IP=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
# The base compose file gates `app` and `backup` on APP_IMAGE_TAG via
# `${APP_IMAGE_TAG:?...}`. Compose interpolates each file before applying
# the dev overlay, so the gate trips even when the overlay re-introduces
# `build: .`. `dev` is a placeholder — the local build's output tag only;
# the dev overlay replaces the runtime image for `app`, and `backup` is
# behind a profile that is never activated in dev. Production
# (docker-compose.yml only, no overlay) sets this from scripts/deploy.sh.
APP_IMAGE_TAG=dev
