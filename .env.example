# =============================================================================
# Projekt-Manager — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values.
# Lines marked [CHANGE IN PROD] MUST be changed before production deployment.
# =============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
# Connection string for the application.
# Docker default: postgresql://pm:<POSTGRES_PASSWORD>@db:5432/projekt_manager
# Local default:  postgresql://pm:<POSTGRES_PASSWORD>@localhost:5432/projekt_manager
DATABASE_URL=postgresql://pm:changeme@localhost:5432/projekt_manager

# Password for the 'pm' database user.                         [CHANGE IN PROD]
POSTGRES_PASSWORD=changeme

# --- Object Storage (MinIO container) ----------------------------------------
# Root credentials for the MinIO container itself.              [CHANGE IN PROD]
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# --- Object Storage (application S3 client) ----------------------------------
# How the app connects to the S3-compatible storage.
# In Docker: http://storage:9000 — In local dev: http://localhost:9000
# NOTE: STORAGE_ACCESS_KEY / STORAGE_SECRET_KEY must match MINIO_ROOT_USER /
# MINIO_ROOT_PASSWORD respectively (same credentials, different context).
STORAGE_ENDPOINT=http://storage:9000
STORAGE_BUCKET=projekt-manager
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme

# --- Application -------------------------------------------------------------
# Fully qualified domain for Caddy reverse proxy / TLS cert.   [CHANGE IN PROD]
DOMAIN=localhost

# Port the Fastify server listens on (inside the container).
PORT=3000

# Runtime mode. Controls security checks, logging verbosity, seed prevention.
# Values: development | production
NODE_ENV=development

# Seed mode (dev only — ignored when NODE_ENV=production):
#   true  = seed if database is empty (safe default)
#   force = wipe and re-seed (when seed data structure changes)
#   false = skip seeding
SEED=true
