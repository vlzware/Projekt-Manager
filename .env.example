# Projekt-Manager — Local Development
# ====================================
# Two-step setup, no edits needed:
#   1. cp .env.example .env
#   2. scripts/binary-key/init-local-key.sh
#      → prints BINARY_AGE_RECIPIENT + BINARY_AGE_IDENTITY_PATH —
#        paste both lines into .env (see § Binary attachment e2e
#        encryption below). The script is idempotent and can be re-run
#        any time to recover the recipient.
#
# For production, see .env.production.example.

# --- Database ---
DATABASE_URL=postgresql://pm:changeme@localhost:5432/projekt_manager
POSTGRES_PASSWORD=changeme

# --- Object Storage (MinIO) ---
# Root credentials run the MinIO process and provision the app user.
# The app NEVER uses these — see ADR-0022 / docs/ops/object-storage-provisioning.md.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
# Capability-restricted app user (#45 / ADR-0022). Provisioned by
# docker/init-storage.sh with a bucket-scoped policy that mirrors the
# prod B2 app key: write/read/list/hide allowed, DeleteObjectVersion
# denied. The boot-time capability self-test in
# src/server/storage/safety.ts refuses to start if the running credential
# can destroy versions — so the app MUST run as this user, not root.
MINIO_APP_ACCESS_KEY=pmapp
MINIO_APP_SECRET_KEY=pmappsecret
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=projekt-manager
# Isolated bucket for the Playwright suite — provisioned alongside
# STORAGE_BUCKET by docker/init-storage.sh and selected by the playwright
# webServer override (see playwright.config.ts). Must differ from
# STORAGE_BUCKET; the init script refuses identical values. Mirrors the
# `_e2e`-suffixed Postgres database isolation (projekt_manager_e2e).
STORAGE_BUCKET_E2E=projekt-manager-e2e
# SigV4 region. MinIO accepts any value; us-east-1 is the SDK default
# and matches what the integration-test bucket assumes.
STORAGE_REGION=us-east-1
# Mirror of the MINIO_APP_* values above — the dev MinIO user the init
# script provisions. Vitest integration runs that hit storage directly
# (no compose path) read these to satisfy the boot capability probe.
STORAGE_ACCESS_KEY=pmapp
STORAGE_SECRET_KEY=pmappsecret

# Dev-MinIO bucket dials (ADR-0022 / docs/ops/object-storage-provisioning.md).
# Read by docker/init-storage.sh; mirror the prod B2 settings so dev tests
# catch divergence. Override for a longer trash window during exploratory work.
# STORAGE_OBJECT_LOCK_DAYS=1               # default Compliance retention (R)
# STORAGE_LIFECYCLE_HIDE_TO_DELETE_DAYS=2  # noncurrent-version reap delay (L)

# --- Application ---
DOMAIN=localhost
PORT=3000
NODE_ENV=development

# Seed demo data on first start. Set to "force" to wipe and re-seed.
SEED=true

# How often (minutes) the background reaper sweeps expired sessions from
# the DB. Positive integer; default 60. Lower values tighten revocation
# latency at the cost of more DB traffic.
# SESSION_CLEANUP_INTERVAL_MINUTES=60

# --- LLM Email Extraction (ADR-0016, optional) ---
# Feature is disabled when the key is absent.
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Binary attachment e2e encryption (ADR-0024) ---
# Both vars are required — the boot probe (assertBinaryIdentityLoaded)
# refuses to start the server without a private identity at
# BINARY_AGE_IDENTITY_PATH whose derived public recipient matches
# BINARY_AGE_RECIPIENT. Bootstrap once with:
#
#   scripts/binary-key/init-local-key.sh
#
# It generates the keypair (idempotent — safe to re-run) and prints
# the two values to paste here. The dev identity protects nothing of
# value (test data only); the boot-probe shape mirrors production
# exactly so the dev loop exercises the same probe contract.
BINARY_AGE_RECIPIENT=
BINARY_AGE_IDENTITY_PATH=

# --- Web Push / VAPID (ADR-0023) ---
# Leave VAPID_PRIVATE_KEY unset in dev — the server auto-generates one
# on first boot and persists it under data/.vapid/private-key. To pin a
# specific key (e.g. share across devs), generate one with
#   npx web-push generate-vapid-keys --json
# and set VAPID_PRIVATE_KEY. The matching public key is derived at boot
# and served to the client via GET /api/push/vapid-public-key.
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@localhost

# --- Not used in dev (production only) ---
CLOUDFLARE_API_TOKEN=
WG_BIND_IP=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
# The base compose file gates `app` and `backup` on APP_IMAGE_TAG via
# `${APP_IMAGE_TAG:?...}`. Compose interpolates each file before applying
# the dev overlay, so the gate trips even when the overlay re-introduces
# `build: .`. `dev` is a placeholder — the local build's output tag only;
# the dev overlay replaces the runtime image for `app`, and `backup` is
# behind a profile that is never activated in dev. Production
# (docker-compose.yml only, no overlay) sets this from scripts/deploy.sh.
APP_IMAGE_TAG=dev
