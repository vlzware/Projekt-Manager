# Projekt-Manager — Production (VPS)
# ====================================
# cp .env.production.example .env — then fill in the values below.
#
# Secrets (POSTGRES_PASSWORD, MINIO_ROOT_PASSWORD, CLOUDFLARE_API_TOKEN)
# go in secrets.env.age, NOT here. See docs/ops/manual-deploy.md.
#
# docker-compose.yml hardcodes DATABASE_URL, STORAGE_*, NODE_ENV, and
# PORT in the container environment — do not set them here.

DOMAIN=<your-domain>
WG_BIND_IP=10.213.17.1
MINIO_ROOT_USER=<chosen-username>
SEED=false

# How often (minutes) the background reaper sweeps expired sessions from
# the DB. Positive integer; default 60. Lower values tighten revocation
# latency at the cost of more DB traffic.
# SESSION_CLEANUP_INTERVAL_MINUTES=60

# --- First-run admin bootstrap (remove after first login) ---
# See ADR-0010 and docs/ops/server-setup.md Phase 8.1.
# Password: ≥8 chars, ≤72 UTF-8 bytes, not in common-password blocklist.
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_DISPLAY_NAME=
