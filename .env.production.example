# Projekt-Manager — Production (VPS)
# ====================================
# cp .env.production.example .env — then fill in the values below.
#
# Secrets (POSTGRES_PASSWORD, STORAGE_SECRET_KEY, CLOUDFLARE_API_TOKEN, ...)
# go in secrets.env.age, NOT here. See docs/ops/manual-deploy.md.
#
# docker-compose.yml hardcodes DATABASE_URL, NODE_ENV, and PORT in the
# container environment — do not set them here.

DOMAIN=<your-domain>
WG_BIND_IP=10.213.17.1
SEED=false

# --- Object storage (Backblaze B2 — ADR-0022) ---
# Production talks to a B2 bucket directly via the S3-compatible
# surface. The bucket is provisioned per
# docs/ops/object-storage-provisioning.md (versioned, Compliance Object
# Lock, single canonical lifecycle rule); the credential is a
# capability-restricted app key (writeFiles/readFiles/listFiles only).
# The boot-time safety probe (src/server/storage/safety.ts) refuses to
# start if any of those invariants drift.
#
# STORAGE_ENDPOINT — the regional S3 endpoint for the bucket. Find it
# in the B2 web console (Buckets → bucket → "S3 API" panel). Format:
#   https://s3.<region>.backblazeb2.com
STORAGE_ENDPOINT=https://s3.<region>.backblazeb2.com
# STORAGE_REGION — must match the region in STORAGE_ENDPOINT exactly
# (e.g. eu-central-003, us-west-002). B2 verifies SigV4 against the
# bucket-bound region and rejects mismatches with SignatureDoesNotMatch.
STORAGE_REGION=<region>
# STORAGE_BUCKET — the bucket name created in the B2 console. The app
# key is bucket-scoped to this name; the boot-time probe queries this
# bucket's versioning / Object Lock / lifecycle config.
STORAGE_BUCKET=<bucket-name>
# STORAGE_ACCESS_KEY — the keyId from `b2 key create … readFiles,
# writeFiles,listFiles`. The matching applicationKey is
# STORAGE_SECRET_KEY in secrets.env.age. The master key MUST NOT be
# used here (it carries deleteFiles, breaking the capability split).
STORAGE_ACCESS_KEY=<keyId>
# STORAGE_PUBLIC_ENDPOINT — leave empty for B2. The app signs presigned
# URLs against STORAGE_ENDPOINT, which the browser can reach directly.
# Set this only when STORAGE_ENDPOINT is a container-only host the
# browser cannot resolve (not applicable in the B2 prod topology).
STORAGE_PUBLIC_ENDPOINT=

# How often (minutes) the background reaper sweeps expired sessions from
# the DB. Positive integer; default 60. Lower values tighten revocation
# latency at the cost of more DB traffic.
# SESSION_CLEANUP_INTERVAL_MINUTES=60

# Login-rate-limit ceiling (logins per minute per IP). Positive integer.
# When unset, getRateLimit() picks env-aware defaults (5/min in production,
# 30/min elsewhere). Override only if you have a reason — a higher value
# weakens brute-force resistance, a lower value risks locking out humans.
# LOGIN_RATE_LIMIT_MAX=5

# --- First-run admin bootstrap (remove after first login) ---
# See ADR-0010 and docs/ops/server-setup.md Phase 8.1.
# Password: ≥8 chars, ≤72 UTF-8 bytes, not in common-password blocklist.
# BOOTSTRAP_ADMIN_USERNAME=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_DISPLAY_NAME=

# --- Web Push / VAPID (ADR-0023) ---
# Required to deliver push notifications. VAPID_PRIVATE_KEY belongs in
# secrets.env.age (never reaches the client); the public half is derived
# at boot and served via GET /api/push/vapid-public-key. When the private
# key is missing the server falls back to a no-op dispatcher and the UI
# opt-in surfaces a "not configured" notice. Generate a key with
#   npx web-push generate-vapid-keys --json
# and keep it stable across deploys — rotating invalidates every browser
# subscription in the push_subscriptions table.
# VAPID_SUBJECT=mailto:admin@<your-domain>

# --- HTTP-only evaluation deployments (ADR-0013) ---
# Set to "true" ONLY for evaluation deployments without a TLS-terminating
# domain. Disables the Secure flag on session cookies so login works over
# plain HTTP. The server REFUSES to start with this set under production
# (NODE_ENV is hardcoded to production by docker-compose.yml) —
# assertProductionSafe() in src/server/config/env.ts is the gate.
# See docs/ops/http-only-evaluation.md.
# ALLOW_INSECURE_HTTP=false

# --- Audit-log retention (ADR-0021, AC-184) ---
# Window: how many days of audit-log rows to keep before the periodic
# cleanup deletes them. Empty (the default) uses the build-time constant
# in src/config/auditRetention.ts (90 days). Positive integer.
# Interval: how often (minutes) the cleanup runs. Default 1440 (daily).
# AUDIT_RETENTION_WINDOW_DAYS=90
# AUDIT_RETENTION_INTERVAL_MINUTES=1440

# --- Attachments (data-model.md §5.13, architecture.md §12.2) ---
# All caps and TTLs are operator-tunable; build-time defaults live in
# src/config/attachmentConfig.ts. Leave empty to use the defaults.
# ATTACHMENT_PER_FILE_CAP_BYTES=
# ATTACHMENT_THUMB_CAP_BYTES=
# ATTACHMENT_BULK_MAX_FILES=
# ATTACHMENT_BULK_MAX_BYTES=
# ATTACHMENT_ORPHAN_REAPER_TTL_MINUTES=
# ATTACHMENT_ORPHAN_REAPER_INTERVAL_MINUTES=
# ATTACHMENT_HIDDEN_REAPER_TTL_MINUTES=
# ATTACHMENT_HIDDEN_REAPER_INTERVAL_MINUTES=
# ATTACHMENT_WORKER_SELF_DELETE_GRACE_MINUTES=

# --- OpenRouter LLM extraction (ADR-0016) ---
# Optional feature — disabled when OPENROUTER_API_KEY is unset.
# OPENROUTER_API_KEY belongs in secrets.env.age (it is a paid API token).
# OPENROUTER_MODEL is the model slug; default is google/gemini-2.5-flash-lite
# in env.ts. Override only if you have a reason (cost/latency profile).
# OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Layer 2 backup destination (ADR-0020) ---
# R2 bucket name and region — both have working defaults in env.ts
# (projekt-manager-backups / auto). Override only when targeting a
# differently-named bucket (e.g. for a parallel test environment).
# R2_BUCKET=projekt-manager-backups
# R2_REGION=auto

# --- Drill-key tmpfs path (AC-175) ---
# Where load-drill-key.sh writes the operator-loaded age private identity
# inside the backup container. Default matches the tmpfs mount declared
# in docker-compose.yml — change only in lockstep with the mount target.
# AGE_IDENTITY_PATH=/run/drill-key/identity

# --- Binary attachment e2e encryption (ADR-0024) ---
# BINARY_AGE_RECIPIENT lives in secrets.env.age (co-managed with the
# private identity, rotated together — same convention as AGE_RECIPIENT
# for backup); see secrets.manifest.txt. The private identity is
# operator-loaded into the tmpfs mount on the app service via
# scripts/binary-key/load-binary-key.sh after each VPS reboot; the boot
# probe refuses to start without it. Lost identity = unrecoverable
# customer deliverables — replicate the private half to ≥2 off-system
# locations per docs/ops/binary-key/setup.md.
#
# Where load-binary-key.sh writes the private identity inside the app
# container. Default matches the tmpfs mount declared in docker-compose.yml.
# BINARY_AGE_IDENTITY_PATH=/run/binary-key/identity
